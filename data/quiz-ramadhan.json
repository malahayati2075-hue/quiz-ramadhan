        // ============ GLOBAL VARIABLES ============
        let allQuestions = [];
        let currentQuestions = [];
        let currentQuestionIndex = 0;
        let score = 0;
        let correctAnswers = 0;
        let playerName = 'Player';
        let timerInterval = null;
        let timeLeft = 20;

        // Leaderboard simulation (stored in localStorage for persistence)
        let leaderboard = JSON.parse(localStorage.getItem('quizLeaderboard')) || [
            { name: "Ahmad Fauzi", score: 950 },
            { name: "Fatimah Azzahra", score: 920 },
            { name: "Muhammad Rizki", score: 890 },
            { name: "Aisyah Putri", score: 850 },
            { name: "Umar Abdullah", score: 820 }
        ];

        // ============ INITIALIZATION ============
        document.addEventListener('DOMContentLoaded', () => {
            initParticles();
            flattenQuestions();
            renderLeaderboard();
        });

        // Create floating particles
        function initParticles() {
            const container = document.getElementById('particles');
            for(let i=0; i<15; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                const size = Math.random() * 4 + 2;
                p.style.width = `${size}px`;
                p.style.height = `${size}px`;
                p.style.left = `${Math.random() * 100}%`;
                p.style.animationDuration = `${Math.random() * 10 + 10}s`;
                p.style.animationDelay = `${Math.random() * 5}s`;
                container.appendChild(p);
            }
        }

        // Flatten JSON structure for easier randomization
        function flattenQuestions() {
            allQuestions = [];
            quizDatabase.quiz_ramadhan.forEach(category => {
                category.questions.forEach(q => {
                    allQuestions.push({
                        ...q,
                        category: category.category
                    });
                });
            });
            // Update stats
            document.getElementById('count-questions').textContent = allQuestions.length;
            document.getElementById('count-categories').textContent = quizDatabase.quiz_ramadhan.length;
        }

        // ============ LEADERBOARD ============
        function renderLeaderboard() {
            const container = document.getElementById('leaderboard-container');
            // Sort by score
            const sorted = [...leaderboard].sort((a, b) => b.score - a.score).slice(0, 10);
            
            container.innerHTML = sorted.map((item, index) => `
                <div class="leaderboard-row flex items-center gap-4 p-3 rounded-xl ${index < 3 ? 'bg-slate-800/50' : 'bg-transparent'}" style="animation-delay: ${index * 0.05}s">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold ${getRankClass(index)}">
                        ${index + 1}
                    </div>
                    <div class="flex-1">
                        <div class="font-semibold text-sm">${item.name}</div>
                    </div>
                    <div class="text-amber-400 font-bold">${item.score}</div>
                </div>
            `).join('');
        }

        function getRankClass(index) {
            if(index === 0) return 'rank-1';
            if(index === 1) return 'rank-2';
            if(index === 2) return 'rank-3';
            return 'bg-slate-700 text-slate-300';
        }

        function saveToLeaderboard(name, finalScore) {
            leaderboard.push({ name, score: finalScore });
            localStorage.setItem('quizLeaderboard', JSON.stringify(leaderboard));
        }

        // ============ QUIZ LOGIC ============
        function startGame() {
            playerName = document.getElementById('playerName').value.trim() || 'Anonim';
            
            // Shuffle and pick 10 questions
            currentQuestions = shuffleArray(allQuestions).slice(0, 10);
            currentQuestionIndex = 0;
            score = 0;
            correctAnswers = 0;

            goToSlide('quiz');
            loadQuestion();
        }

        function loadQuestion() {
            if(currentQuestionIndex >= currentQuestions.length) {
                endGame();
                return;
            }

            const q = currentQuestions[currentQuestionIndex];
            
            // Update UI
            document.getElementById('current-q-num').textContent = currentQuestionIndex + 1;
            document.getElementById('current-score').textContent = score;
            document.getElementById('progress-bar').style.width = `${((currentQuestionIndex) / 10) * 100}%`;
            document.getElementById('q-category').textContent = q.category;
            document.getElementById('question-text').textContent = q.question;

            // Shuffle options
            const shuffledOptions = shuffleArray([...q.options]);

            const container = document.getElementById('options-container');
            container.innerHTML = shuffledOptions.map((opt, i) => `
                <div class="option-item glass-card rounded-xl p-4 flex items-center gap-4" onclick="selectAnswer(this, '${opt.replace(/'/g, "\\'")}')">
                    <div class="w-8 h-8 rounded-full border border-slate-600 flex items-center justify-center text-sm font-bold text-slate-400">
                        ${String.fromCharCode(65 + i)}
                    </div>
                    <div class="flex-1 font-medium">${opt}</div>
                </div>
            `).join('');

            startTimer();
        }

        function startTimer() {
            clearInterval(timerInterval);
            timeLeft = 20;
            document.getElementById('timer-text').textContent = timeLeft + 's';
            document.getElementById('timer-circle').style.strokeDasharray = '100, 100';

            timerInterval = setInterval(() => {
                timeLeft--;
                document.getElementById('timer-text').textContent = timeLeft + 's';
                // stroke-dasharray logic for circular progress
                const percent = 100 - ((20 - timeLeft) / 20 * 100);
                document.getElementById('timer-circle').style.strokeDasharray = `${percent}, 100`;

                if(timeLeft <= 0) {
                    clearInterval(timerInterval);
                    handleTimeout();
                }
            }, 1000);
        }

        function handleTimeout() {
            // Auto-select wrong (no selection)
            const q = currentQuestions[currentQuestionIndex];
            const options = document.querySelectorAll('.option-item');
            
            options.forEach(opt => {
                const optText = opt.querySelector('.flex-1').textContent;
                if(optText === q.answer) {
                    opt.classList.add('correct');
                }
                opt.style.pointerEvents = 'none'; // Disable clicks
            });

            setTimeout(() => {
                currentQuestionIndex++;
                loadQuestion();
            }, 1500);
        }

        function selectAnswer(element, selectedOpt) {
            clearInterval(timerInterval);
            const q = currentQuestions[currentQuestionIndex];
            const options = document.querySelectorAll('.option-item');
            
            let isCorrect = false;
            if(selectedOpt === q.answer) {
                element.classList.add('correct');
                isCorrect = true;
                correctAnswers++;
                score += 10 + timeLeft; // Points + time bonus
            } else {
                element.classList.add('wrong');
                // Highlight correct answer
                options.forEach(opt => {
                    const optText = opt.querySelector('.flex-1').textContent;
                    if(optText === q.answer) {
                        opt.classList.add('correct');
                    }
                });
            }

            // Disable all options
            options.forEach(opt => opt.style.pointerEvents = 'none');

            // Show explanation (optional UI feedback)
            // For now, we just proceed
            setTimeout(() => {
                currentQuestionIndex++;
                loadQuestion();
            }, 1200);
        }

        function endGame() {
            clearInterval(timerInterval);
            
            // Save to leaderboard
            saveToLeaderboard(playerName, score);
            renderLeaderboard();

            // Calculate Grade
            let grade = 'C';
            if(correctAnswers >= 9) grade = 'A+';
            else if(correctAnswers >= 8) grade = 'A';
            else if(correctAnswers >= 7) grade = 'B+';
            else if(correctAnswers >= 6) grade = 'B';
            else if(correctAnswers >= 5) grade = 'C';

            // Update Result Slide
            document.getElementById('result-player-name').textContent = playerName;
            document.getElementById('final-score').textContent = score;
            document.getElementById('final-correct').textContent = correctAnswers;
            document.getElementById('final-wrong').textContent = 10 - correctAnswers;
            document.getElementById('final-grade').textContent = grade;

            goToSlide('result');
        }

        // ============ NAVIGATION ============
        function goToSlide(slideName) {
            document.querySelectorAll('.slide').forEach(s => s.classList.remove('active'));
            document.getElementById('slide-' + slideName).classList.add('active');
        }

        function playAgain() {
            startGame();
        }

        function goHome() {
            goToSlide('home');
        }

        function exitGame() {
            if(confirm('Yakin ingin keluar dari quiz?')) {
                goHome();
                clearInterval(timerInterval);
            }
        }

        // ============ UTILITIES ============
        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }
    </script>
</body>
</html>
